# ===== Ollama =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=8192

# ===== Server =====
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*

# ===== Workspace =====
# Absolute path to the repo root the assistant is allowed to operate on.
# All filesystem and git tools are sandboxed to this directory.
WORKSPACE_ROOT=C:/Users/Desktop/AI_coding_assistant

# ===== Storage =====
DATA_DIR=./data
SQLITE_PATH=./data/assistant.sqlite
CHROMA_PATH=./data/chroma

# ===== Terminal MCP (safety) =====
# Comma-separated list of allowed top-level executables.
TERMINAL_ALLOWLIST=git,python,pytest,pip,ls,dir,cat,type,grep,rg,echo,pwd,cd,docker,kubectl,npm,node
TERMINAL_TIMEOUT_SECONDS=60
TERMINAL_MAX_OUTPUT_BYTES=200000

# ===== Agent =====
AGENT_MAX_ITERATIONS=12
AGENT_RECURSION_LIMIT=40
